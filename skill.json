{
  "name": "agency-agents-zh-manage",
  "slug": "agency-agents-zh-manage",
  "version": "0.1.0",
  "description": "Manage the agency-agents-zh role library on demand across macOS and Windows: find, preview, install, remove, sync, and maintain the dependency repo for Codex or OpenClaw.",
  "type": "skill",
  "entry": {
    "kind": "script",
    "path": "skills/agency-agents-zh-manage/scripts/agency-agents-zh-manage.sh"
  },
  "skill_dir": "skills/agency-agents-zh-manage",
  "metadata_sources": {
    "skill_markdown": "skills/agency-agents-zh-manage/SKILL.md",
    "agent_manifest": "skills/agency-agents-zh-manage/agents/openai.yaml"
  },
  "supported_tools": [
    "codex",
    "openclaw"
  ],
  "capabilities": [
    "find_roles",
    "preview_role",
    "list_installed",
    "install_role_codex",
    "install_role_openclaw",
    "remove_installed_role",
    "sync_manifest",
    "install_dependency_repo",
    "update_dependency_repo",
    "doctor_environment"
  ],
  "install": {
    "mode": "copy_skill_directory",
    "source": "skills/agency-agents-zh-manage"
  },
  "dependencies": {
    "requires_local_repo": true,
    "repo_name": "agency-agents-zh",
    "repo_resolution_order": [
      "--repo /path/to/agency-agents-zh",
      "AGENCY_AGENTS_REPO",
      "./vendor/agency-agents-zh",
      "../agency-agents-zh",
      "~/.agency/vendor/agency-agents-zh",
      "~/.codex/vendor/agency-agents-zh",
      "~/.openclaw/vendor/agency-agents-zh"
    ]
  },
  "tags": [
    "skills",
    "agents",
    "roles",
    "codex",
    "openclaw",
    "cli"
  ],
  "license": "MIT"
}
